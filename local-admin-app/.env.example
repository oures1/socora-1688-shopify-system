PORT=4877
DATA_DIR=/app/data
SMALLORDER_TEMPLATE=/app/templates/smallorder.xlsx
PYTHON=python3

# local: data/store.json に保存
# supabase: Supabaseの admin_store テーブルに保存
STORE_BACKEND=local
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORE_TABLE=admin_store
SUPABASE_STORE_KEY=main

# Renderなどで公開する場合は必ず設定
ADMIN_PASSWORD=
SESSION_SECRET=

# Shopify追跡番号反映
SHOPIFY_STORE_DOMAIN=y9wpse-tn.myshopify.com
SHOPIFY_ADMIN_ACCESS_TOKEN=
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=
SHOPIFY_API_VERSION=2026-04
SHOPIFY_TRACKING_COMPANY=Sagawa Express
# カラー画像をShopifyへ自動反映する。止める場合だけ 0 にする
SHOPIFY_AUTO_MEDIA_ENABLED=1
SHOPIFY_ADMIN_STORE_SLUG=y9wpse-tn
LOCAL_STORE_MIN_PRODUCT_NO=0
LOCAL_STORE_MIN_ORDER_NO=0
LOCAL_STORE_BACKUP_ON_WRITE=1
